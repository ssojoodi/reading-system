# Required for interpretation generation
OPENAI_API_KEY=
READER_MODEL=gpt-5-mini
OPENAI_BASE_URL=https://api.openai.com/v1

# Required for Mailgun delivery
MAILGUN_API_KEY=
MAILGUN_DOMAIN=mg.example.com
MAILGUN_FROM=Your Name <you@example.com>
RECIPIENTS=you@example.com,friend@example.com

# Optional: deployment path used by run.sh
BASE_DIR=/path/to/personal-librarian

# Required for Django web app deployment
DJANGO_SECRET_KEY=change-me
DJANGO_DEBUG=false
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# Optional: SQLite database path for the Django web app
DATABASE_PATH=/app/data/db.sqlite3
